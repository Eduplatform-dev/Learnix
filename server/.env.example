NODE_ENV=development

PORT=5000

# MongoDB connection string
# Local:  mongodb://localhost:27017/learnix
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/learnix
MONGO_URI=mongodb://localhost:27017/learnix

# Must be at least 16 characters — change this to a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Must match exactly the URL your Vite dev server runs on
CORS_ORIGIN=http://localhost:5173

# Public URL for uploaded file links (leave blank for auto-detect)
PUBLIC_BASE_URL=http://localhost:5000

# ─── AI Configuration ────────────────────────────────────────────────────────
# Option 1: Google Gemini (FREE — 1500 requests/day on free tier)
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Option 2: Anthropic Claude (paid but high quality)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Note: If both keys are set, Anthropic (Claude) takes priority.
# For a free final year project, use GEMINI_API_KEY only.
